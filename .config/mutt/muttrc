source ~/.config/mutt/colors
source ~/.config/mutt/keybindings
source ~/.config/mutt/aliases

set sort=threads sort_aux=reverse-last-date-received

set include
set forward_quote

# set pager_index_lines=10
# set pager_context=3
set pager_read_delay = 5
set pager_stop

# Mail Editor
set editor           = nvim

# Sidebar
set sidebar_width=28
set sidebar_visible
set sidebar_format   = "%B%<F? [%F]>%* %<N?%N/>%S"
set mail_check_stats

set header_cache     = "~/.cache/mutt/"
set message_cachedir = "~/.cache/mutt/"

