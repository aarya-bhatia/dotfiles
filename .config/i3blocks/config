separator=false

[kernel]
command=echo " " $(uname -r)
interval=once
color=#ff0000

[volume]
command=sb-volume
interval=once
signal=5
color=#ff00ff

[battery]
command=sb-battery
interval=5
color=#00ff00

[weather]
command=sb-weather
interval=60
color=#00ffff

[disk]
command=sb-disk
interval=30
color=#ffff00

[memory]
command=sb-memory
interval=30
color=#ff0000

[date]
command=sb-date
interval=5
color=#00ff00

# vim: ft=ini
