# signal=10

[battery]
command=~/scripts/battery.sh
interval=5

[ip]
command=printf " %s\n" $(hostname -i | cut -d" " -f1)
interval=360
label=

[time]
command=date +'%A, %d %B %I:%M %p '
interval=10

