[mediaplayer]
command=~/scripts/mediaplayer.sh
interval=5

[kernel]
command=printf " %s\n" $(uname -a | cut -d" " -f3)
interval=once
label=

[weather]
command=~/scripts/weather.py -f
interval=360

[disk]
command=~/scripts/disk.py
interval=360

