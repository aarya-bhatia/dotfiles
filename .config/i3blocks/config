[window]
command=xdotool getactivewindow getwindowname
interval=persist

[click]
full_text=Click me!
command=echo "Got clicked with button $button"
color=#F79494

# get the weather every ten min
[weather]
command=~/scripts/weather.py 2>/dev/null
interval=360
color=#A4C2F4

# Query my default IP address only on startup
[ip]
command=hostname -I | awk '{ print "IP:" $1 }'
interval=once
color=#91E78B

# Update time every 5 seconds
[time]
command=date +%T
interval=5

