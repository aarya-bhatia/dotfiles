# i3 config file (v4)
# Please see https://i3wm.org/docs/userguide.html for a complete reference!

# mod1 = Alt
set $mod Mod1

# mod4 = windows key
set $mod4 Mod4

bindsym $mod+Shift+c reload
bindsym $mod+Shift+r restart
bindsym $mod+Shift+e exec --no-startup-id "i3-nagbar -t warning -m 'Do you really want to exit i3?' -B 'Yes, exit i3' 'i3-msg exit'"
bindsym $mod+Shift+x exec --no-startup-id systemctl suspend
bindsym $mod+Shift+s exec --no-startup-id  killall -SIGUSR1 sxhkd && notify-send "i3" "sxhkd reloaded"

set $primary eDP-1
set $secondary HDMI-1

font pango:monospace 8

focus_wrapping no
ipc-socket ~/.i3/i3-ipc.sock
popup_during_fullscreen smart
workspace_auto_back_and_forth yes

set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"
set $ws11 "11"
set $ws12 "12"
set $ws13 "13"
set $ws14 "14"
set $ws15 "15"
set $ws16 "16"
set $ws17 "17"
set $ws18 "18"
set $ws19 "19"
set $ws20 "20"

workspace 1 output $primary
workspace 2 output $primary
workspace 3 output $primary
workspace 4 output $primary
workspace 5 output $primary
workspace 6 output $primary
workspace 7 output $primary
workspace 8 output $primary
workspace 9 output $primary
workspace 10 output $primary

workspace 11 output $secondary
workspace 12 output $secondary
workspace 13 output $secondary
workspace 14 output $secondary
workspace 15 output $secondary
workspace 16 output $secondary
workspace 17 output $secondary
workspace 18 output $secondary
workspace 19 output $secondary
workspace 20 output $secondary

bindsym $mod+1 workspace $WS1
bindsym $mod+2 workspace $WS2
bindsym $mod+3 workspace $WS3
bindsym $mod+4 workspace $WS4
bindsym $mod+5 workspace $WS5
bindsym $mod+6 workspace $WS6
bindsym $mod+7 workspace $WS7
bindsym $mod+8 workspace $WS8
bindsym $mod+9 workspace $WS9
bindsym $mod+0 workspace $WS10

bindsym $mod4+1 workspace $WS11
bindsym $mod4+2 workspace $WS12
bindsym $mod4+3 workspace $WS13
bindsym $mod4+4 workspace $WS14
bindsym $mod4+5 workspace $WS15
bindsym $mod4+6 workspace $WS16
bindsym $mod4+7 workspace $WS17
bindsym $mod4+8 workspace $WS18
bindsym $mod4+9 workspace $WS19
bindsym $mod4+0 workspace $WS20

bindsym $mod+Shift+1 move container to workspace $WS1
bindsym $mod+Shift+2 move container to workspace $WS2
bindsym $mod+Shift+3 move container to workspace $WS3
bindsym $mod+Shift+4 move container to workspace $WS4
bindsym $mod+Shift+5 move container to workspace $WS5
bindsym $mod+Shift+6 move container to workspace $WS6
bindsym $mod+Shift+7 move container to workspace $WS7
bindsym $mod+Shift+8 move container to workspace $WS8
bindsym $mod+Shift+9 move container to workspace $WS9
bindsym $mod+Shift+0 move container to workspace $WS10

bindsym $mod4+Shift+1 move container to workspace $WS11
bindsym $mod4+Shift+2 move container to workspace $WS12
bindsym $mod4+Shift+3 move container to workspace $WS13
bindsym $mod4+Shift+4 move container to workspace $WS14
bindsym $mod4+Shift+5 move container to workspace $WS15
bindsym $mod4+Shift+6 move container to workspace $WS16
bindsym $mod4+Shift+7 move container to workspace $WS17
bindsym $mod4+Shift+8 move container to workspace $WS18
bindsym $mod4+Shift+9 move container to workspace $WS19
bindsym $mod4+Shift+0 move container to workspace $WS20

# Use Mouse+$mod to drag floating windows to their wanted position
floating_modifier $mod

# enable floating mode for windows where class name begins with floating
for_window [class="^floating"] floating enable

# Terminal
bindsym $mod+Return exec --no-startup-id alacritty --class=Alacritty
bindsym $mod+Shift+Return exec --no-startup-id alacritty --class=floating

for_window [class="^.*"] border pixel 1

# use window title *and* a thick border
bindsym $mod+y border normal 3

# use neither window title nor border
bindsym $mod+u border none

# i3 gaps

# Set inner/outer gaps
set $gaps_inner 6
set $gaps_outer 1

gaps inner $gaps_inner
gaps outer $gaps_outer

smart_gaps on
smart_borders on
hide_edge_borders smart_no_gaps

# Assign Workspaces:
# assign [class="Firefox"] $ws2
assign [class="thunderbird"] $ws3
assign [class="discord"] $ws3
assign [class="Slack"] $ws3
assign [class="vlc"] $ws5
assign [class="Code"] $ws6
assign [class="Pavucontrol"] $ws9
assign [class="floating-ncmpcpp"] $ws5
assign [class="Virt-manager"] $ws7

for_window [class="Qalculate"] floating enable

bindcode 148 exec --no-startup-id alacritty --class="floating" -e qalc

# toggle window in scratchpad
bindcode $mod+148 [class="Qalculate"] scratchpad show

# open clipmenu
bindsym $mod+c exec --no-startup-id clipmenu

bindsym $mod+i exec --no-startup-id ~/scripts/dmenu_open_images.sh

# kill focused window
bindsym $mod+Shift+q kill

bindsym $mod+Tab workspace next
bindsym $mod+Shift+Tab workspace prev

# change focus
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

# move focused window
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

# split in horizontal orientation
bindsym $mod+z split h

# split in vertical orientation
bindsym $mod+v split v

# enter fullscreen mode for the focused container
bindsym $mod+f fullscreen toggle

# change container layout (stacked, tabbed, toggle split)
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split

# toggle tiling / floating
bindsym $mod+Shift+space floating toggle

# change focus between tiling / floating windows
bindsym $mod+space focus mode_toggle

# focus the parent container
bindsym $mod+a focus parent

# focus the child container
bindsym $mod+semicolon focus child

bindsym $mod+Shift+minus move scratchpad
bindsym $mod+minus scratchpad show

for_window [class="Thunar"] floating enable resize set 960 750

# Launch calculator
bindsym $mod+g [class="Gnome-calculator"] scratchpad show
for_window [class="Gnome-calculator"] floating enable

# bindcode $mod+107 exec --no-startup-id ~/scripts/screenshot.sh -s

bar {
	status_command 2>/tmp/i3blocks.err i3blocks
	position top
	tray_output eDP-1
	font pango:Hack Nerd Font 9.5
}

# resize window
mode "resize" {
  bindsym h resize shrink width 20 px or 20 ppt
  bindsym k resize grow height 20 px or 20 ppt
  bindsym j resize shrink height 20 px or 20 ppt
  bindsym l resize grow width 20 px or 20 ppt

  bindsym Return mode "default"
  bindsym Escape mode "default"
}
bindsym $mod+r mode "resize"

set $mode_filemarks [1]configs [2]scripts [3]stat107 [4]cs233 [5]hdfs220 [6]cs340
mode "$mode_filemarks" {
    bindsym 1 exec --no-startup-id alacritty -e /bin/bash -c "cd /home/aarya/.config && /bin/bash", mode "default"
    bindsym 2 exec --no-startup-id alacritty -e /bin/bash -c "cd /home/aarya/scripts && /bin/bash", mode "default"
    bindsym 3 exec --no-startup-id alacritty -e /bin/bash -c "cd /home/aarya/GoogleDrive/uiuc/senior/spring/STAT107 && /bin/bash", mode "default"
    bindsym 4 exec --no-startup-id alacritty -e /bin/bash -c "cd /home/aarya/GoogleDrive/uiuc/senior/spring/CS233 && /bin/bash", mode "default"
    bindsym 5 exec --no-startup-id alacritty -e /bin/bash -c "cd /home/aarya/GoogleDrive/uiuc/senior/spring/CS233 && /bin/bash", mode "default"
    bindsym 6 exec --no-startup-id alacritty -e /bin/bash -c "cd /home/aarya/cs340-illinois && /bin/bash", mode "default"

    bindsym Escape mode "default"
    bindsym Return mode "default"
}

bindsym $mod+Shift+m mode "$mode_filemarks"

set $mode_gaps Gaps: (o) outer, (i) inner
set $mode_gaps_outer Outer Gaps: +|-|0 (local), Shift + +|-|0 (global), g (edit gaps)
set $mode_gaps_inner Inner Gaps: +|-|0 (local), Shift + +|-|0 (global), g (edit gaps)
bindsym $mod+Shift+g mode "$mode_gaps"

mode "$mode_gaps" {
        bindsym o      mode "$mode_gaps_outer"
        bindsym i      mode "$mode_gaps_inner"
        bindsym Return mode "default"
        bindsym Escape mode "default"
}

mode "$mode_gaps_inner" {
        bindsym plus  gaps inner current plus 5
        bindsym minus gaps inner current minus 5
        bindsym 0     gaps inner current set 0

        bindsym Shift+plus  gaps inner all plus 5
        bindsym Shift+minus gaps inner all minus 5
        bindsym Shift+0     gaps inner all set 0

		bindsym g mode "$mode_gaps"

        bindsym Return mode "default"
        bindsym Escape mode "default"
}

mode "$mode_gaps_outer" {
        bindsym plus  gaps outer current plus 5
        bindsym minus gaps outer current minus 5
        bindsym 0     gaps outer current set 0

        bindsym Shift+plus  gaps outer all plus 5
        bindsym Shift+minus gaps outer all minus 5
        bindsym Shift+0     gaps outer all set 0

		bindsym g mode "$mode_gaps"

        bindsym Return mode "default"
        bindsym Escape mode "default"
}

# Start simple x hotkey daemon
exec --no-startup-id sxhkd &

# Start music player daemon
exec --no-startup-id mpd &

# Network manager
exec --no-startup-id nm-applet &

# Display wallpaper
exec --no-startup-id ~/scripts/wallpaper.sh

# Window compositor
exec --no-startup-id picom --backend glx --xrender-sync-fence &

# Always turn on num lock
exec --no-startup-id numlockx on

# Remap Caps Lock to ESC/Control key
exec_always --no-startup-id ~/scripts/keymaps.sh

# Dunst notification daemon
exec --no-startup-id dunst &

# start clipmenu deamon
exec --no-startup-id clipmenud &

# mirror display with HDMI-1 monitor if connected
exec_always --no-startup-id ~/scripts/screenmirror.sh

# lock screen on suspend
# exec --no-startup-id xss-lock --transfer-sleep-lock -- i3lock -e --nofork

# Auto lock screen and suspend after some amount of idle time
exec --no-startup-id ~/scripts/screenlock.sh

