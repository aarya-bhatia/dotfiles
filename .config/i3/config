# i3 config file (v4)
# Please see https://i3wm.org/docs/userguide.html for a complete reference!

# mod1 = Alt
set $mod Mod1

# mod4 = windows key
set $mod4 Mod4

bindsym $mod+Shift+c reload
bindsym $mod+Shift+r restart
bindsym $mod+Shift+e exec --no-startup-id "i3-nagbar -t warning -m 'Do you really want to exit i3?' -B 'Yes, exit i3' 'i3-msg exit'"

set $primary eDP-1
set $secondary HDMI-1

# font pango:monospace 8
font pango:JetBrains Mono 1

focus_wrapping no
ipc-socket ~/.i3/i3-ipc.sock
popup_during_fullscreen smart
workspace_auto_back_and_forth yes

set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"
set $ws11 "11"
set $ws12 "12"
set $ws13 "13"
set $ws14 "14"
set $ws15 "15"
set $ws16 "16"
set $ws17 "17"
set $ws18 "18"
set $ws19 "19"
set $ws20 "20"

# set $ws1 :
# set $ws2 2:
# set $ws3 3:
# set $ws4 4:
# set $ws5 5:♫
# set $ws7 7:
# set $ws9 9:

set $ws1 1:term
set $ws2 2:www
set $ws3 3:mail
set $ws4 4:doc
set $ws5 5:media
set $ws6 6:code
set $ws9 9:sys

# Terminal
set $terminal 'alacritty'
set $termclass 'Alacritty'

# i3 gaps
for_window [class="^.*"] border pixel 1
# for_window [class=".*"] title_format ""

# Set inner/outer gaps
set $gaps_inner 6
set $gaps_outer 1

gaps inner $gaps_inner
gaps outer $gaps_outer

smart_gaps on
smart_borders on
hide_edge_borders smart_no_gaps

include modes.conf
include workspace.conf
include colors.conf

# Assign Workspaces:
assign [class="thunderbird"] $ws3
assign [class="discord"] $ws3
assign [class="Slack"] $ws3
assign [class="vlc"] $ws5
assign [class="Firefox"] $ws2
assign [class="Code"] $ws6
assign [class="Pavucontrol"] $ws9
assign [class="floating-ncmpcpp"] $ws5

bindsym XF86AudioRaiseVolume exec --no-startup-id $HOME/scripts/external/volume_brightness.sh volume_up
bindsym XF86AudioLowerVolume exec --no-startup-id $HOME/scripts/external/volume_brightness.sh volume_down
bindsym XF86AudioMute exec --no-startup-id $HOME/scripts/external/volume_brightness.sh volume_mute
bindsym XF86MonBrightnessUp exec --no-startup-id $HOME/scripts/external/volume_brightness.sh brightness_up
bindsym XF86MonBrightnessDown exec --no-startup-id $HOME/scripts/external/volume_brightness.sh brightness_down
# bindsym XF87AudioPlayPause exec --no-startup-id $HOME/scripts/external/volume_brightness.sh play_pause
bindsym XF86AudioPause exec --no-startup-id $HOME/scripts/external/volume_brightness.sh play_pause
bindsym XF86AudioPlay exec --no-startup-id $HOME/scripts/external/volume_brightness.sh play_pause
bindsym XF86AudioNext exec --no-startup-id $HOME/scripts/external/volume_brightness.sh next_track
bindsym XF86AudioPrev exec --no-startup-id $HOME/scripts/external/volume_brightness.sh prev_track

bindsym $mod+XF86AudioPause exec --no-startup-id mpc toggle
bindsym $mod+XF86AudioPlay exec --no-startup-id mpc toggle
bindsym $mod+XF86AudioNext exec --no-startup-id mpc next
bindsym $mod+XF86AudioPrev exec --no-startup-id mpc prev

# Use Mouse+$mod to drag floating windows to their wanted position
floating_modifier $mod

# start a terminal
# bindsym $mod+Return exec --no-startup-id i3-sensible-terminal
bindsym $mod+Return exec --no-startup-id $terminal

# enable floating mode for windows where class name begins with floating
for_window [class="^floating"] floating enable
for_window [class="Qalculate"] floating enable

# bindsym $mod+Shift+Return [class="floating-term"] scratchpad show
# bindsym $mod+p [class="floating-python"] scratchpad show

bindsym $mod+Control+Return exec --no-startup-id alacritty --class=floating-term -e tmux new-session -A -s term
bindsym $mod+Control+p exec --no-startup-id alacritty --class=floating-python -e tmux new-session -A -s python3 "/home/aarya/pyvenv/bin/python3"
bindsym $mod+Control+q exec --no-startup-id alacritty --class=floating-qalc -e tmux new-session -A -s qalc "qalc"
bindsym $mod+Control+v exec ~/scripts/launch_vim.sh

bindcode 148 exec --no-startup-id qalculate

# toggle window in scratchpad
bindcode $mod+148 [class="Qalculate"] scratchpad show

bindsym $mod+Control+c exec --no-startup-id ~/scripts/dmenu_open_config.sh

bindsym $mod+Control+w exec --no-startup-id sxiv ~/wallpapers

# kill focused window
bindsym $mod+Shift+q kill

# Open rofi program launcher
bindsym $mod+d exec --no-startup-id dmenu_run

bindsym $mod+Tab workspace next
bindsym $mod+Shift+Tab workspace prev

# change focus
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

# move focused window
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

# split in horizontal orientation
bindsym $mod+z split h

# split in vertical orientation
bindsym $mod+v split v

# enter fullscreen mode for the focused container
bindsym $mod+f fullscreen toggle

# change container layout (stacked, tabbed, toggle split)
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split

# toggle tiling / floating
bindsym $mod+Shift+space floating toggle

# change focus between tiling / floating windows
bindsym $mod+space focus mode_toggle

# focus the parent container
bindsym $mod+a focus parent

# focus the child container
bindsym $mod+semicolon focus child

bindsym $mod+Shift+minus move scratchpad
bindsym $mod+minus scratchpad show

# Network manager
exec_always --no-startup-id nm-applet &

# Display random wallpaper
exec_always --no-startup-id ~/.fehbg &
bindsym $mod+Shift+w exec --no-startup-id ~/scripts/wallpaper.sh &

# Window compositor
exec_always --no-startup-id killall -q picom; picom --config ~/.config/picom.conf --backend glx --xrender-sync-fence &

# Remap Caps Lock to Control key
exec_always --no-startup-id ~/scripts/keymaps.sh

# Dunst notification daemon
exec_always --no-startup-id dunst &

# mirror display with HDMI-1 monitor if connected
exec_always --no-startup-id ~/scripts/screenmirror.sh

# Auto lock screen and suspend after some amount of idle time
exec_always --no-startup-id ~/scripts/screenlock.sh &

# Always turn on num lock
exec_always --no-startup-id numlockx on

# Start mpd daemon
exec --no-startup-id mpd &

# Launch file browser
bindsym $mod+t exec --no-startup-id thunar &
for_window [class="Thunar"] floating enable resize set 960 750

# Launch music player
bindsym XF86Tools exec --no-startup-id alacritty --class=floating-ncmpcpp -e ncmpcpp

# Launch calculator
# bindsym $mod+Shift+g exec --no-startup-id gnome-calculator &
bindsym $mod+g [class="Gnome-calculator"] scratchpad show
for_window [class="Gnome-calculator"] floating enable

# bindsym $mod+Shift+x exec --no-startup-id betterlockscreen --time-format "%r" --lock dim --off 60
bindsym $mod+Shift+x exec --no-startup-id i3lock && systemctl suspend

# dmenu password input
bindsym $mod+Shift+p exec --no-startup-id ~/scripts/external/dmenupass.sh

# Screenshots with Print key
bindsym Print exec --no-startup-id ~/scripts/screenshot.sh
bindcode $mod+107 exec --no-startup-id ~/scripts/screenshot.sh -s

# i3status bar
bar {
	status_command i3status
	tray_output eDP-1
	# tray_output primary
	position top
	font pango:DejaVu Sans Mono 9
	workspace_min_width 25
}

