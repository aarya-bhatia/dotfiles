# for testing
alt + z
	notify-send "hello world"

# terminal emulator
super + Return
	alacritty

# terminal emulator
alt + Return
	alacritty

# program launcher
alt + d
	dmenu_run -h 24

# make sxhkd reload its configuration files:
alt + Escape
	pkill -USR1 -x sxhkd; \
	notify-send "reloaded sxhkd"; \
	sleep 1; \
	/home/aarya/scripts/keymaps.sh &

# quit bspwm
alt + shift + x
	test $(echo -e "Yes\nNo\n" | dmenu -p "Are you sure want to quit?") = "Yes" && bspc quit

# restart bspwm
alt + shift + r
	bspc wm -r && /home/aarya/.config/bspwm/bspwmrc

# close and kill
alt + {_,shift + }q
	bspc node -{c,k}

# switch to desktop
alt + {0-9}
	bspc desktop -f {0-9}

# alternate between the tiled and monocle layout
alt + m
	bspc desktop -l next

# next/prev desktop
alt + {_,shift + } Tab
	bspc desktop -f {next,prev}

# focus/swap nodes in direction
alt + {_,shift + }{h,j,k,l}
	bspc node -{f,s} {west,south,north,east}

# focus/swap nodes in direction
alt + {_,shift + }{Left,Down,Up,Right}
	bspc node -{f,s} {west,south,north,east}

# focus the next/previous desktop in the current monitor
alt + bracket{left,right}
	bspc desktop -f {prev,next}.local

# focus the next/previous window in the current desktop
alt + {_,shift + }c
	bspc node -f {next,prev}.local.!hidden.window

# focus or send to the given desktop
alt + {_,shift + }{1-9,0}
	bspc {desktop -f,node -d} '^{1-9,10}'

# volume keys
{XF86AudioRaiseVolume,XF86AudioLowerVolume,XF86AudioMute}
	$HOME/scripts/volume.sh {up,down,mute}

# brightness keys
{XF86MonBrightnessUp,XF86MonBrightnessDown}
	$HOME/scripts/volume.sh {brightness_up,brightness_down}

# multimedia keys
{XF86AudioNext,XF86AudioPrev,XF86AudioPause,XF86AudioPlay}
	$HOME/scripts/volume.sh {next_track,prev_track,play_pause,play_pause}

# Smart resize, will grow or shrink depending on location.
# Will always grow for floating nodes.
alt + ctrl + super + {Left,Down,Up,Right}
  n=20; \
  { d1=left;   d2=right;  dx=-$n; dy=0;   \
  , d1=bottom; d2=top;    dx=0;   dy=$n;  \
  , d1=top;    d2=bottom; dx=0;   dy=-$n; \
  , d1=right;  d2=left;   dx=$n;  dy=0;   \
  } \
  bspc node --resize $d1 $dx $dy || bspc node --resize $d2 $dx $dy

# seek music player
alt + super + {0-9}
	mpc -q seek {0-9}0%

alt + space
	bsp-layout next --layouts tall,rtall,wide,rwise,grid,tiled,monocle; \
	current=$(bsp-layout get); \
	notify-send "layout changed: $current"

alt + f1
	bsp-layout next --layouts tall,rtall,wide,rwise,grid,tiled,monocle; \
	current=$(bsp-layout get); \
	notify-send "layout changed: $current"

alt + o; {v,f,t,d}
