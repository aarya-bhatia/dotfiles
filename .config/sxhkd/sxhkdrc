# General syntax:
#
#    HOTKEY
# 	   [;]COMMAND
#
#    HOTKEY      := CHORD_1 ; CHORD_2 ; ... ; CHORD_n
#    CHORD_i     := [MODIFIERS_i +] [~][@]KEYSYM_i
#    MODIFIERS_i := MODIFIER_i1 + MODIFIER_i2 + ... + MODIFIER_ik
#
# The valid modifier names are: super, hyper, meta, alt, control, ctrl, shift, mode_switch, lock,
# mod1, mod2, mod3, mod4, mod5 and any.

{XF86AudioRaiseVolume,XF86AudioLowerVolume,XF86AudioMute,XF86MonBrightnessUp,XF86MonBrightnessDown}
	$HOME/scripts/volume.sh {up,down,mute,brightness_up,brightness_down}

{XF87AudioPlayPause,XF86AudioPause,XF86AudioPlay}
	$HOME/scripts/external/volume_brightness.sh {play_pause,play_pause,play_pause}

{XF86AudioNext,XF86AudioPrev}
	$HOME/scripts/external/volume_brightness.sh {next_track,prev_track}

alt+{XF86AudioPause,XF86AudioPlay,XF86AudioNext,XF86AudioPrev}
	mpc {toggle,toggle,next,prev}

# Launch music player
XF86Tools
	alacritty --class=floating-ncmpcpp -e ncmpcpp

alt+o
	$HOME/scripts/dmenu_launch_app.sh

alt+t
	thunar

alt+shift+w
	sxiv ~/wallpapers

alt+Return
	alacritty

alt+control+p
	alacritty --class=floating-python -e tmux new-session -A -s python3 "/home/aarya/pyvenv/bin/python3"

alt+control+q
	alacritty --class=floating-qalc -e tmux new-session -A -s qalc "qalc"

alt+Escape
	/home/aarya/scripts/dmenu_power.sh

alt+control+v
	~/scripts/launch_vim.sh

# Open rofi program launcher
alt+d
	dmenu_run

alt+shift+w
	~/scripts/wallpaper.sh

alt+shift+x
	i3lock && systemctl suspend

# dmenu password input
alt+shift+p
	~/scripts/external/dmenupass.sh

# Screenshots with Print key
Print
	~/scripts/screenshot.sh || notify-send "aarya" "screenshot failed"

alt+Print
	~/scripts/screenshot.sh -u || notify-send "aarya" "screenshot failed"

# For testing
alt+shift+z
	notify-send "PATH" "$PATH"

alt+shift+t; h
	alacritty --class='floating-htop' -e htop

alt+shift+t; v
	alacritty --class='floating-vim' -e vim

alt+shift+t; n
	alacritty --class='floating-ncmpcpp' -e ncmpcpp


