XF86AudioRaiseVolume
	$HOME/scripts/volume.sh up

XF86AudioLowerVolume
	$HOME/scripts/volume.sh down

XF86AudioMute
	$HOME/scripts/volume.sh mute

XF86MonBrightnessUp
	$HOME/scripts/volume.sh brightness_up

XF86MonBrightnessDown
	$HOME/scripts/volume.sh brightness_down

XF86AudioPause
	$HOME/scripts/volume.sh play_pause

XF86AudioPlay
	$HOME/scripts/volume.sh play_pause

XF86AudioNext
	$HOME/scripts/volume.sh next_track

XF86AudioPrev
	$HOME/scripts/volume.sh prev_track

# terminal emulator
super + Return
	alacritty

# program launcher
super + @d
	dmenu_run

# make sxhkd reload its configuration files:
super + Escape
	pkill -USR1 -x sxhkd && notify-send "reloaded sxhkd"

super + z
	notify-send "hello world"

# quit/restart bspwm
super + shift + {x,r}
	bspc {quit,wm -r}

# close and kill
super + {_,shift + }q
	bspc node -{c,k}

# switch to desktop
super + {0-9}
	bspc desktop -f {0-9}

# superernate between the tiled and monocle layout
super + m
	bspc desktop -l next

super + {_,shift + }{h,j,k,l}
	bspc node -{f,s} {west,south,north,east}

# focus the next/previous desktop in the current monitor
super + bracket{left,right}
	bspc desktop -f {prev,next}.local

# focus the next/previous window in the current desktop
super + {_,shift + }c
	bspc node -f {next,prev}.local.!hidden.window

# focus or send to the given desktop
super + {_,shift + }{1-9,0}
	bspc {desktop -f,node -d} '^{1-9,10}'

