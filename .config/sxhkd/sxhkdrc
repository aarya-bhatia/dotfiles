# General syntax:
#
#    HOTKEY
# 	   [;]COMMAND
#
#    HOTKEY      := CHORD_1 ; CHORD_2 ; ... ; CHORD_n
#    CHORD_i     := [MODIFIERS_i +] [~][@]KEYSYM_i
#    MODIFIERS_i := MODIFIER_i1 + MODIFIER_i2 + ... + MODIFIER_ik
#
# The valid modifier names are: super, hyper, meta, alt, control, ctrl, shift, mode_switch, lock,
# mod1, mod2, mod3, mod4, mod5 and any.

XF86AudioRaiseVolume
	$HOME/scripts/external/volume_brightness.sh volume_up

XF86AudioLowerVolume
	$HOME/scripts/external/volume_brightness.sh volume_down

XF86AudioMute
	$HOME/scripts/external/volume_brightness.sh volume_mute

XF86MonBrightnessUp
	$HOME/scripts/external/volume_brightness.sh brightness_up

XF86MonBrightnessDown
	$HOME/scripts/external/volume_brightness.sh brightness_down

XF87AudioPlayPause
	$HOME/scripts/external/volume_brightness.sh play_pause

XF86AudioPause
	$HOME/scripts/external/volume_brightness.sh play_pause

XF86AudioPlay
	$HOME/scripts/external/volume_brightness.sh play_pause

XF86AudioNext
	$HOME/scripts/external/volume_brightness.sh next_track

XF86AudioPrev
	$HOME/scripts/external/volume_brightness.sh prev_track

alt+XF86AudioPause
	mpc toggle

alt+XF86AudioPlay
	mpc toggle

alt+XF86AudioNext
	mpc next

alt+XF86AudioPrev
	mpc prev

# Launch music player
XF86Tools
	alacritty --class=floating-ncmpcpp -e ncmpcpp

alt+o
	chosen = $(printf "firefox\nthunderbird\ndiscord\nchromium\n" | dmenu -p "Launch >")
	case $chosen in
		"discord") discord ;;
		"thunderbird") thunderbird ;;
		"chromium") chormium ;;
	esac

alt+t
	thunar

alt+shift+w
	sxiv ~/wallpapers

alt+Return
	alacritty

alt+control+p
	alacritty --class=floating-python -e tmux new-session -A -s python3 "/home/aarya/pyvenv/bin/python3"

alt+control+q
	alacritty --class=floating-qalc -e tmux new-session -A -s qalc "qalc"

alt+Escape
	/home/aarya/scripts/dmenu_power.sh

alt+control+v
	~/scripts/launch_vim.sh

# Open rofi program launcher
alt+d
	dmenu_run

alt+shift+w
	~/scripts/wallpaper.sh

alt+shift+x
	i3lock && systemctl suspend

# dmenu password input
alt+shift+p
	~/scripts/external/dmenupass.sh

# Screenshots with Print key
Print
	~/scripts/screenshot.sh

# For testing
alt+shift+z
	notify-send "PATH" "$PATH"

